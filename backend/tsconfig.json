{
  "compilerOptions": {
    "target": "es2019",
    "module": "commonjs",
    "ignoreDeprecations": "6.0",
    "lib": [
      "es2019",
      "es2020.promise",
      "es2020.bigint",
      "es2020.string"
    ],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./src",
    // --- ADICIONE ESTAS LINHAS AQUI ---
    "typeRoots": [
      "./src/@types",
      "./node_modules/@types"
    ],
    // ----------------------------------
    "moduleResolution": "node",
    "resolveJsonModule": true
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}